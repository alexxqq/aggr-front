# Copy to .env and adjust for your local environment

# API Gateway base URL (no trailing slash)
NUXT_PUBLIC_API_BASE_URL=http://localhost:8000

# --- Firebase web app config ---
# Get these from Firebase Console → Project Settings → Your apps → Web app
# Project: crypto-aggregator-73307
NUXT_PUBLIC_FIREBASE_API_KEY=           # required — paste your web API key here
NUXT_PUBLIC_FIREBASE_AUTH_DOMAIN=crypto-aggregator-73307.firebaseapp.com
NUXT_PUBLIC_FIREBASE_PROJECT_ID=crypto-aggregator-73307

# --- Local dev auth bypass ---
# Set to "true" to skip real Firebase auth and use a static dev token
NUXT_PUBLIC_DEV_BYPASS=false
# The static token forwarded as "Authorization: Bearer <token>" in dev mode
# Must match DEV_BYPASS_TOKEN in the API Gateway .env
NUXT_PUBLIC_DEV_BYPASS_TOKEN=dev-bypass-token
# Firebase UID and email forwarded to the gateway via X-Dev-Firebase-Uid / X-Dev-Email
# The gateway uses these to bootstrap (or look up) the merchant in User Service
NUXT_PUBLIC_DEV_BYPASS_UID=dev-uid
NUXT_PUBLIC_DEV_BYPASS_EMAIL=dev@example.com
